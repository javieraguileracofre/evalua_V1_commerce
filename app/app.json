{
  "expo": {
    "name": "Evalua V1 Commerce",
    "slug": "evalua-v1-commerce",
    "scheme": "evaluav1commerce",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "baseUrl": "/evalua_V1_commerce"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permite usar la camara para escanear codigos de barras."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "cl.evalua.commerce"
    },
    "android": {
      "package": "cl.evalua.commerce"
    },
    "extra": {
      "eas": {
        "projectId": "replace-with-eas-project-id"
      }
    }
  }
}
